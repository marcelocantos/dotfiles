#!/usr/bin/env python3
"""Scan ~/work repos with CLAUDE.md and generate active-projects.md."""

import os
import re
import subprocess
from pathlib import Path

WORK = Path.home() / "work" / "github.com"
OUTPUT = Path.home() / "think" / "active-projects.md"


def git_last_commit_date(repo: Path) -> str:
    """Return ISO date of most recent commit, or '' on failure."""
    try:
        out = subprocess.check_output(
            ["git", "-C", str(repo), "log", "-1", "--format=%cs"],
            stderr=subprocess.DEVNULL,
            text=True,
        ).strip()
        return out
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def extract_summary(claude_md: Path) -> str:
    """Extract a one-line summary from a CLAUDE.md file.

    Strategy: skip boilerplate, headings, tables, code blocks, and
    directive-style lines. Take the first line that reads like a
    project description.
    """
    try:
        text = claude_md.read_text()
    except OSError:
        return ""

    skip_prefixes = (
        "#", "|", "```", "-", "*", ">",
        "This file provides guidance",
        "Override:", "Use Vera", "Guidance for",
        "cargo ", "make ", "go ", "npm ", "uv ",
    )

    in_code_block = False
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("```"):
            in_code_block = not in_code_block
            continue
        if in_code_block or not stripped:
            continue
        if any(stripped.startswith(p) for p in skip_prefixes):
            continue
        # Skip very short lines (labels, field names)
        if len(stripped) < 20:
            continue
        if len(stripped) > 100:
            stripped = stripped[:97] + "..."
        return stripped

    return ""


def main():
    repos = []
    for claude_md in sorted(WORK.rglob("CLAUDE.md")):
        # Only top-level CLAUDE.md (direct child of repo root)
        repo_dir = claude_md.parent
        rel = repo_dir.relative_to(WORK)
        parts = rel.parts
        if len(parts) != 2:
            continue

        org, name = parts
        last_commit = git_last_commit_date(repo_dir)
        summary = extract_summary(claude_md)
        path = f"~/work/github.com/{org}/{name}"
        repos.append((org, name, path, summary, last_commit))

    # Sort: most recently committed first
    repos.sort(key=lambda r: r[4], reverse=True)

    lines = [
        "# Active Projects",
        "",
        f"Auto-generated by `update-active-projects`. {len(repos)} repos with CLAUDE.md.",
        "",
        "| Project | Org | Path | Last Commit | Summary |",
        "|---|---|---|---|---|",
    ]
    for org, name, path, summary, last_commit in repos:
        lines.append(f"| {name} | {org} | `{path}` | {last_commit} | {summary} |")

    lines.append("")
    OUTPUT.write_text("\n".join(lines))
    print(f"Wrote {len(repos)} repos to {OUTPUT}")


if __name__ == "__main__":
    main()
