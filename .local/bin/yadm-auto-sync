#!/bin/bash
# Auto-commit and push yadm-tracked dotfiles if there are changes.
# Intended to run via launchd every 30 minutes.

set -uo pipefail

LOG="$HOME/.local/var/log/yadm-auto-sync.log"
STATE_DIR="$HOME/.local/state"
FAILURE_COUNTER="$STATE_DIR/yadm-auto-sync.failures"
ALERT_THRESHOLD=3
mkdir -p "$STATE_DIR"
export PATH="/opt/homebrew/bin:$PATH"

# Bound a half-dead TCP session — a push without these can hang for hours,
# blocking every subsequent launchd invocation. ~45s ceiling on a stuck push.
export GIT_SSH_COMMAND="ssh -o ConnectTimeout=15 -o ServerAliveInterval=10 -o ServerAliveCountMax=3"

ts() { date '+%Y-%m-%d %H:%M:%S'; }

# True iff there are local commits not yet on the upstream branch.
has_unpushed() {
  local n
  n=$(yadm rev-list --count '@{u}..HEAD' 2>/dev/null) || return 1
  [ "$n" -gt 0 ]
}

# Push, manage consecutive-failure counter, alert only on threshold crossing.
# Single notification when N consecutive failures accumulate; further failures
# stay quiet until a success resets the counter. $1 names the push operation
# for log readability, e.g. "post-commit push" or "pending-commits push".
push_with_backoff_alert() {
  local op="$1"
  if yadm push >> "$LOG" 2>&1; then
    echo 0 > "$FAILURE_COUNTER"
    echo "[$(ts)] ok: $op" >> "$LOG"
    return 0
  fi
  local n=1
  [ -f "$FAILURE_COUNTER" ] && n=$(($(cat "$FAILURE_COUNTER") + 1))
  echo "$n" > "$FAILURE_COUNTER"
  echo "[$(ts)] ERROR: $op failed (consecutive=$n)" >> "$LOG"
  if [ "$n" -eq "$ALERT_THRESHOLD" ]; then
    alerter --title "yadm-auto-sync" \
      --message "Push has failed $n consecutive times — check ~/.local/var/log/yadm-auto-sync.log" \
      --sound default
  fi
  return 1
}

# No working-tree changes — but a previous push may have failed, leaving
# commits stranded. Push them before exiting; otherwise the next file edit
# is the only thing that retries.
if yadm diff --quiet && yadm diff --cached --quiet; then
  if has_unpushed; then
    push_with_backoff_alert "pending-commits push"
  else
    echo "[$(ts)] heartbeat: no changes" >> "$LOG"
  fi
  exit 0
fi

# Commit and push, capturing errors.
if yadm add -u && yadm commit -m "auto-sync dotfiles ($(date '+%Y-%m-%d %H:%M'))" >> "$LOG" 2>&1; then
  push_with_backoff_alert "post-commit push"
else
  echo "[$(ts)] ERROR: commit failed" >> "$LOG"
  alerter -title "yadm-auto-sync" -message "Commit failed — check ~/.local/var/log/yadm-auto-sync.log" -sound default
fi
