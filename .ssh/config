# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

#VisualHostKey=yes
Host *
  UseKeychain yes
  AddKeysToAgent yes

Host learner learner.local
  HostName learner.local
  IdentityFile ~/.ssh/learner
  IdentitiesOnly yes

Host catflap catflap.local
  User marcelo
  HostName 192.168.1.218
  IdentityFile ~/.ssh/id_rsa
  IdentitiesOnly yes

Host rpi raspberrypi.local
  User pi
  HostName raspberrypi.local
  IdentityFile ~/.ssh/raspberrypi
  IdentitiesOnly yes

Host athome concierge concierge.local
  User marcelo
  HostName concierge.local
  IdentityFile ~/.ssh/concierge
  IdentitiesOnly yes

Host george mac.lan
  HostName mac.lan
  Port 22
  IdentityFile ~/.ssh/george_ed25519
  IdentitiesOnly yes

Host 192.168.123.2
  Port 22
  IdentityFile ~/.ssh/george_ed25519
  IdentitiesOnly yes

Host 192.168.123.3
  Port 22
  IdentityFile ~/.ssh/george_ed25519
  IdentitiesOnly yes

Host home
  User marcelo
  HostName 1.tcp.au.ngrok.io
  IdentityFile ~/.ssh/concierge
  IdentitiesOnly yes
  LocalForward 22001 learner.local:22
  Port 25953

Host learner.tunnel
  HostName localhost
  Port 22001
  IdentityFile ~/.ssh/learner
  IdentitiesOnly yes
